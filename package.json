{
  "name": "zhiaiwan-template-vsce-server",
  "displayName": "Zhiaiwan Template Server",
  "description": "VSCode/Cursor 扩展基础骨架，内置可复用的 Node 服务。",
  "version": "0.1.0",
  "publisher": "local",
  "private": true,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/qq61538187/zhiaiwan-template-vsce-server.git"
  },
  "engines": {
    "vscode": "^1.85.0",
    "node": ">=20"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "*"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "nodeServerExtension.restartServer",
        "title": "Template Server: 重启服务"
      },
      {
        "command": "nodeServerExtension.checkProbeCommands",
        "title": "Template Server: 探测命令检查"
      },
      {
        "command": "nodeServerExtension.openServiceLog",
        "title": "Template Server: 打开服务日志文件"
      }
    ],
    "configuration": {
      "title": "Template Server 扩展",
      "properties": {
        "nodeServerExtension.port": {
          "type": "number",
          "default": 3510,
          "description": "内置 Node 服务使用的端口。"
        }
      }
    }
  },
  "scripts": {
    "bundle": "node ./scripts/build.mjs",
    "watch": "node ./scripts/build.mjs --watch",
    "typecheck": "tsc -p . --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "test": "vitest",
    "test:run": "vitest run",
    "test:ci": "vitest run --passWithNoTests",
    "commit": "cz",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:status": "changeset status --verbose",
    "example:health": "node ./examples/health-check.mjs",
    "bootstrap": "node ./scripts/bootstrap.mjs",
    "compile": "npm run bundle && npm run typecheck",
    "package:vsix": "npm run compile && vsce package --no-dependencies --allow-star-activation --readme-path README.vsce.md",
    "pretest": "npm run compile",
    "prepare": "husky"
  },
  "dependencies": {
    "compression": "^1.8.0",
    "cors": "^2.8.5",
    "express": "^5.2.1",
    "helmet": "^8.1.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^10.0.1",
    "@types/compression": "^1.8.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.6",
    "@types/node": "^22.13.14",
    "@types/supertest": "^7.2.0",
    "@types/vscode": "^1.85.0",
    "commitizen": "^4.3.1",
    "cz-git": "^1.12.0",
    "esbuild": "^0.25.10",
    "eslint": "^10.0.3",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "supertest": "^7.2.2",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.57.1",
    "vitest": "^4.1.0"
  },
  "lint-staged": {
    "*.{ts,mts,cts,js,mjs,cjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "config": {
    "commitizen": {
      "path": "node_modules/cz-git"
    }
  }
}
